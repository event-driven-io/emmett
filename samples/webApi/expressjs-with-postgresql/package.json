{
  "name": "expressjs-with-postgresql",
  "version": "1.0.0",
  "type": "module",
  "description": "Samples WebApi using Event Sourcing using Emmett, Express.js and PostgreSQL",
  "scripts": {
    "setup": "cat .nvmrc | nvm install; nvm use",
    "build": "tsdown",
    "build:ts": "tsc",
    "build:ts:watch": "tsc -b --watch",
    "start": "tsx --import ./src/telemetry.ts ./src/index.ts",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:prettier": "prettier --check \"**/**/!(*.d).{ts,json,md}\"",
    "lint:eslint": "eslint '**/*.ts'",
    "fix": "run-s fix:eslint fix:prettier",
    "fix:prettier": "prettier --write \"**/**/!(*.d).{ts,json,md}\"",
    "fix:eslint": "eslint '**/*.ts' --fix",
    "test": "run-s test:unit test:int test:e2e",
    "test:unit": "glob -d -c \"node --import tsx --test\" **/*.unit.spec.ts",
    "test:int": "glob -d -c \"node --import tsx --test\" **/*.int.spec.ts",
    "test:e2e": "glob -d -c \"node --import tsx --test\" **/*.e2e.spec.ts",
    "test:watch": "run-p test:unit:watch test:int:watch test:e2e:watch",
    "test:unit:watch": "glob -d -c \"node --import tsx --test --watch\" **/*.unit.spec.ts",
    "test:int:watch": "glob -d -c \"node --import tsx --test --watch\" **/*.int.spec.ts",
    "test:e2e:watch": "glob -d -c \"node --import tsx --test --watch\" **/*.e2e.spec.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/event-driven-io/emmett.git"
  },
  "keywords": [
    "Event Sourcing"
  ],
  "author": "Oskar Dudycz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/event-driven-io/emmett/issues"
  },
  "homepage": "https://github.com/event-driven-io/emmett#readme",
  "dependencies": {
    "@event-driven-io/emmett": "0.43.0-beta.15",
    "@event-driven-io/emmett-expressjs": "0.43.0-beta.15",
    "@event-driven-io/emmett-postgresql": "0.43.0-beta.15",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/instrumentation-express": "^0.215.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^10.10.3",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "10.3.10",
    "globals": "^17.5.0",
    "npm-run-all2": "6.1.2",
    "pg": "8.20.0",
    "prettier": "^3.8.3",
    "tsconfig-paths": "4.2.0",
    "tsdown": "^0.21.9",
    "tsx": "4.7.1",
    "typescript": "^6.0.3"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
